---
title: "Jorge Andrade-Sánchez"
# Cargar los datos y paquetes necesarios
library(palmerpenguins)
library(ggplot2)
# Filtrar los datos para trabajar con un subconjunto sin valores NA
data <- na.omit(penguins$body_mass_g)
# Visualizar la distribución original de la masa corporal
ggplot(data.frame(body_mass_g = data), aes(x = body_mass_g)) +
geom_histogram(bins = 20, fill = "skyblue", color = "black") +
labs(title = "Distribución original de la masa corporal", x = "Masa corporal (g)", y = "Frecuencia") +
theme_minimal()
# Simulación para el TLC
set.seed(42) # Para reproducibilidad
n_samples <- 1000  # Número de muestras
sample_size <- 30  # Tamaño de cada muestra
# Extraer medias muestrales
means <- replicate(n_samples, mean(sample(data, sample_size, replace = TRUE)))
# Visualizar la distribución de las medias muestrales
ggplot(data.frame(sample_means = means), aes(x = sample_means)) +
geom_histogram(bins = 20, fill = "lightgreen", color = "black") +
labs(
title = "Distribución de las medias muestrales",
x = "Media muestral de masa corporal (g)",
y = "Frecuencia"
) +
theme_minimal()
# Comparar con una distribución normal
ggplot(data.frame(sample_means = means), aes(x = sample_means)) +
geom_histogram(aes(y = ..density..), bins = 20, fill = "lightgreen", color = "black") +
stat_function(fun = dnorm, args = list(mean = mean(means), sd = sd(means)), color = "red
ggplot(data.frame(sample_means = means), aes(x = sample_means)) +
