# Conjunto de datos: Calificaciones de los estudiantes
calificaciones <- c(65, 70, 75, 75, 80, 85, 85, 90, 95, 100)
# Configurar el área de gráficos para mostrar múltiples gráficos (opcional)
par(mfrow = c(1, 2)) # 1 fila, 2 columnas
hist(calificaciones,
main = "Histograma de Calificaciones",
xlab = "Calificaciones",
ylab = "Frecuencia",
col = "skyblue",
border = "black",
breaks = 6)
# 2. Crear el boxplot
boxplot(calificaciones,
main = "Gráfico de Caja de Calificaciones",
ylab = "Calificaciones",
col = "lightgreen",
horizontal = TRUE) #
library(palmerpenguins)
library(ggplot2)
library(dplyr)
data(penguins)
head(penguins)
penguins_clean <- penguins %>%
filter(!is.na(bill_length_mm), !is.na(body_mass_g))
ggplot(penguins_clean, aes(x = bill_length_mm, y = body_mass_g, color = species)) +
geom_point(size = 3, alpha = 0.7) +
geom_smooth(method = "lm", se = TRUE, alpha = 0.2) +
labs(
title = "Correlación entre Longitud del Pico y Masa Corporal en Pingüinos",
subtitle = "Relación morfométrica por especie",
x = "Longitud del Pico (mm)",
y = "Masa Corporal (g)",
color = "Especie",
caption = "Datos: Palmer Penguins Dataset"
) +
scale_color_manual(values = c("darkorange", "purple", "cyan4")) +
theme_minimal() +
theme(
plot.title = element_text(face = "bold", size = 14),
legend.position = "bottom"
)
# Versión más simple - solo una especie (Adelie)
adelie_data <- penguins_clean %>%
filter(species == "Adelie")
# Correlación para Adelie
cor_adelie <- cor(adelie_data$bill_length_mm, adelie_data$body_mass_g)
ggplot(adelie_data, aes(x = bill_length_mm, y = body_mass_g)) +
geom_point(size = 3, alpha = 0.7, color = "darkorange") +
geom_smooth(method = "lm", se = TRUE, color = "darkred", fill = "pink", alpha = 0.3) +
labs(
title = "Correlación Longitud del Pico - Masa Corporal (Pingüinos Adelie)",
subtitle = paste("Correlación de Pearson: r =", round(cor_adelie, 3)),
x = "Longitud del Pico (mm)",
y = "Masa Corporal (g)"
) +
theme_minimal()
