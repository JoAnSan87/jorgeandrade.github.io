plot_interactivo
penguins_clean <- penguins %>% filter(!is.na(bill_length_mm), !is.na(body_mass_g))
plot_interactivo <- plot_ly(
data = penguins_clean,
x = ~bill_length_mm,
y = ~body_mass_g,
color = ~species,
colors = c("darkorange", "purple", "cyan4"),
type = 'scatter',
mode = 'markers'
) %>% layout(
title = "Correlación Interactiva: Longitud del Pico vs Masa Corporal",
xaxis = list(title = "Longitud del Pico (mm)"),
yaxis = list(title = "Masa Corporal (g)")
)
library(palmerpenguins)
library(plotly)
library(dplyr)
penguins_clean <- penguins %>%
filter(!is.na(bill_length_mm), !is.na(body_mass_g))
# Crear gráfico con estilo classic y botones
plot_interactivo <- plot_ly(
data = penguins_clean,
x = ~bill_length_mm,
y = ~body_mass_g,
color = ~species,
colors = c("darkorange", "purple", "cyan4"),
type = 'scatter',
mode = 'markers',
marker = list(size = 10, opacity = 0.8, line = list(width = 1, color = 'darkgray')),
hoverinfo = 'text',
text = ~paste(
'Especie: ', species,
'<br>Longitud pico: ', round(bill_length_mm, 1), ' mm',
'<br>Masa corporal: ', round(body_mass_g, 0), ' g',
'<br>Isla: ', island,
'<br>Sexo: ', ifelse(is.na(sex), "No registrado", sex)
)
)
# Aplicar layout con estilo classic y botones
plot_interactivo <- plot_interactivo %>%
layout(
title = list(
text = "<b>Correlación Interactiva: Longitud del Pico vs Masa Corporal</b>",
x = 0.05,
font = list(size = 16)
),
xaxis = list(
title = "<b>Longitud del Pico (mm)</b>",
gridcolor = '#f0f0f0',
zerolinecolor = '#f0f0f0',
linecolor = 'black',
linewidth = 2
),
yaxis = list(
title = "<b>Masa Corporal (g)</b>",
gridcolor = '#f0f0f0',
zerolinecolor = '#f0f0f0',
linecolor = 'black',
linewidth = 2
),
plot_bgcolor = 'white',
paper_bgcolor = 'white',
font = list(family = "Arial", size = 12),
# Botones interactivos
updatemenus = list(
list(
type = "buttons",
direction = "right",
x = 0.1,
y = 1.15,
buttons = list(
list(method = "update",
args = list(list(visible = rep(TRUE, 3))),
label = "Todas"),
list(method = "update",
args = list(list(visible = c(TRUE, FALSE, FALSE))),
label = "Solo Adelie"),
list(method = "update",
args = list(list(visible = c(FALSE, TRUE, FALSE))),
label = "Solo Chinstrap"),
list(method = "update",
args = list(list(visible = c(FALSE, FALSE, TRUE))),
label = "Solo Gentoo")
)
),
# Botón para resetear zoom
list(
type = "buttons",
direction = "right",
x = 0.7,
y = 1.15,
buttons = list(
list(method = "relayout",
args = list("xaxis.autorange", TRUE),
args2 = list("yaxis.autorange", TRUE),
label = "Reset Zoom")
)
)
),
# Anotaciones informativas
annotations = list(
list(
x = 0.02, y = 0.02,
xref = "paper", yref = "paper",
text = "💡 Click en leyenda o botones para filtrar especies",
showarrow = FALSE,
font = list(size = 10, color = "gray"),
bgcolor = "white",
bordercolor = "lightgray"
)
)
)
# Mostrar el gráfico
plot_interactivo
