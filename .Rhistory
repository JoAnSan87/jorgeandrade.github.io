# 1. Distribución de todos los pesos originales (masa corporal)
# Filtrar los datos para trabajar con masa corporal (sin NA)
data <- na.omit(penguins$body_mass_g)
ggplot(data.frame(body_mass_g = data), aes(x = body_mass_g)) +
geom_histogram(bins = 20, fill = "skyblue", color = "black") +
labs(
title = "Distribución original de la masa corporal (g)",
x = "Masa corporal (g)",
y = "Frecuencia"
) +
theme_classic()
# 2. Ejemplo con muestra pequeña (no se aproxima a la normal)
set.seed(42)  # Para reproducibilidad
# Definir número de muestras pequeñas
n_samples_small <- 10  # Pocas muestras
sample_size_small <- 5  # Tamaño pequeño por muestra
# Extraer medias muestrales
means_small <- replicate(n_samples_small, mean(sample(data, sample_size_small, replace = TRUE)))
ggplot(data.frame(sample_means = means_small), aes(x = sample_means)) +
geom_histogram(bins = 5, fill = "lightcoral", color = "black") +
labs(
title = "Distribución de las medias muestrales (muestra pequeña)",
x = "Media muestral de masa corporal (g)",
y = "Frecuencia"
) +
theme_minimal()
ggplot(data.frame(sample_means = means_small), aes(x = sample_means)) +
geom_histogram(bins = 5, fill = "lightcoral", color = "black") +
labs(
title = "Distribución de las medias muestrales (muestra pequeña)",
x = "Media muestral de masa corporal (g)",
y = "Frecuencia"
) +
theme_classic()
# 3. Ejemplo con muestra grande y comparación con la normal
# Definir número de muestras grandes
n_samples_large <- 1000  # Muchas muestras
sample_size_large <- 30  # Tamaño grande por muestra
nrow(penguins)
ggplot(data.frame(sample_means = means_large), aes(x = sample_means)) +
geom_histogram(aes(y = ..density..), bins = 20, fill = "lightgreen", color = "black") +
stat_function(fun = dnorm, args = list(mean = mean(means_large), sd = sd(means_large)),
color = "red", size = 1) +
labs(
title = "Distribución de medias muestrales (muestra grande)",
x = "Media muestral de masa corporal (g)",
y = "Densidad"
) +
theme_classic()
